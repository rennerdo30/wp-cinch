{
  "name": "rennerdo30/cinch",
  "description": "Dequeues unused assets, concatenates per-page CSS + JS, minifies through the best engine on the host (esbuild then matthiasmullie then regex), and writes brotli + gzip siblings for the edge.",
  "type": "wordpress-plugin",
  "license": "MIT",
  "homepage": "https://github.com/rennerdo30/wp-cinch",
  "authors": [
    { "name": "Renner", "homepage": "https://renner.dev" }
  ],
  "require": {
    "php": ">=8.1",
    "matthiasmullie/minify": "^1.3"
  },
  "autoload": {
    "psr-4": { "Cinch\\": "src/" }
  },
  "scripts": {
    "test": "php tests/MinifierTest.php && php tests/ChainTest.php",
    "lint": "find . -path ./vendor -prune -o -name '*.php' -print -exec php -l {} ;"
  },
  "config": {
    "sort-packages": true
  }
}
